# Synthetic evaluation dataset: keep it committed, but keep git/GitHub from
# "showing" it -- excluded from language stats, collapsed as generated in PRs,
# and treated as non-diffable so `git diff`/`git show` do not print its contents.
datasets/repositories/**        linguist-generated=true linguist-vendored=true
datasets/medium_repositories/** linguist-generated=true linguist-vendored=true -diff
datasets/large_repositories/**  linguist-generated=true linguist-vendored=true -diff
datasets/dataset_overview.csv   linguist-generated=true
